{
  "name": "@qrcl/ink-react",
  "version": "0.1.0",
  "description": "React Ink wrapper for QR console rendering",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --sourcemap --clean --external react --external ink --external @qrcl/core",
    "clean": "rm -rf dist *.tsbuildinfo",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@qrcl/core": "file:../core"
  },
  "peerDependencies": {
    "ink": ">=5.0.0",
    "react": ">=18.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.12"
  }
}
