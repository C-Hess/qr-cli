{
  "name": "@qr-cli/cli",
  "version": "1.0.3",
  "license": "MIT",
  "description": "CLI wrapper for QR console rendering",
  "repository": {
    "type": "git",
    "url": "https://github.com/C-Hess/qr-cli"
  },
  "homepage": "https://github.com/C-Hess/qr-cli",
  "bugs": {
    "url": "https://github.com/C-Hess/qr-cli/issues"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "qr-cli": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vite build",
    "clean": "rm -rf dist *.tsbuildinfo",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@qr-cli/renderer": "^1.0.1"
  }
}
