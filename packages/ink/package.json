{
  "name": "@qr-cli/ink",
  "version": "1.0.1",
  "description": "React Ink wrapper for QR console rendering",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vite build",
    "clean": "rm -rf dist *.tsbuildinfo",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@qr-cli/renderer": "^1.0.1"
  },
  "peerDependencies": {
    "ink": ">=7.0.0",
    "react": ">=19.2.0"
  },
  "devDependencies": {
    "@types/react": "19.2.14"
  }
}
