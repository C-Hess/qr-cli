{
  "name": "@qr-cli/renderer",
  "version": "1.0.3",
  "license": "MIT",
  "description": "Core QR renderer for console output",
  "repository": {
    "type": "git",
    "url": "https://github.com/C-Hess/qr-cli"
  },
  "homepage": "https://github.com/C-Hess/qr-cli",
  "bugs": {
    "url": "https://github.com/C-Hess/qr-cli/issues"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vite build",
    "clean": "rm -rf dist *.tsbuildinfo",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "iconv-lite": "0.6.3",
    "qrcode-generator": "2.0.4"
  }
}
