{
  "name": "qrcl",
  "private": true,
  "version": "0.1.0",
  "description": "Monorepo for QR rendering packages",
  "packageManager": "npm@11.11.0",
  "engines": {
    "node": ">=24.14.1",
    "npm": ">=11.11.0"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build:core": "npm run -w @qrcl/core build",
    "build:cli": "npm run -w @qrcl/cli build",
    "build:ink": "npm run -w @qrcl/ink-react build",
    "build": "npm run --workspaces build",
    "clean": "npm run --workspaces clean",
    "typecheck": "npm run --workspaces typecheck",
    "check": "npm run typecheck && npm run build"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3"
  }
}
